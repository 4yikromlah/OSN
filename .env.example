# ============================================
# SMASA-Online CBT - Konfigurasi Environment
# ============================================

# GEMINI_API_KEY (Wajib untuk fitur AI)
# Dapatkan API key dari: https://aistudio.google.com/apikey
# Digunakan untuk generasi soal otomatis menggunakan Google Gemini AI.
GEMINI_API_KEY="YOUR_GEMINI_API_KEY_HERE"

# PORT (Opsional)
# Port yang digunakan oleh server Express. Default: 3000
# PORT=3000

# NODE_ENV (Opsional)
# Mode environment: "development" atau "production"
# NODE_ENV=production
